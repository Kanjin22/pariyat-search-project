FLASK_SECRET_KEY=replace-with-a-long-random-secret-key
STAFF_USERNAME=เจ้าหน้าที่

# แบบง่าย: ใช้รหัสผ่านแบบข้อความตรงในเครื่องภายใน
# STAFF_PASSWORD=change-this-password

# แบบแนะนำ: ใช้ hash ของรหัสผ่านแทน
STAFF_PASSWORD_HASH=replace-with-generated-password-hash

PARIYAT_API_URL=https://app.pariyat.com/pages/postx/name_json.php
PARIYAT_API_USER=replace-with-api-user
PARIYAT_API_PASS=replace-with-api-pass
PARIYAT_CERT_API_URL=https://app.pariyat.com/pages/postx/license_json.php
# ถ้าไม่กำหนด PARIYAT_CERT_API_USER/PASS จะ fallback ไปใช้ PARIYAT_API_USER/PASS
PARIYAT_CERT_API_USER=
PARIYAT_CERT_API_PASS=

API_SNAPSHOT_MAX_AGE_HOURS=24
PUBLIC_CERTIFICATE_CACHE_TTL_SECONDS=300

RESULTS_DATA_DIR=replace-with-persistent-path-if-needed
